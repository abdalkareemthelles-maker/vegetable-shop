doctype html
html
  head
    meta(charset="UTF-8")
    title الطلبات
    link(rel="stylesheet", href="/css/style.css")

  body

    include includes/header

    h1 🧾 الطلبات

    a(href="/admin")
      button العودة للوحة التحكم

    br
    br

    if orders.length === 0

      h2 لا توجد طلبات حالياً

    else

      each order in orders

        .product

          h2 طلب رقم ##{order.id}

          if order.username
            p 👤 المستخدم: #{order.username}

          p 📞 الجوال: #{order.phone}
          p 🏠 العنوان: #{order.address}
          p 📅 التاريخ: #{order.created_at}
          p 💰 الإجمالي: #{order.total} $

          p
            | 🚚 الحالة الحالية:
            span(id=`status-${order.id}`) #{order.status}

          br

          button(onclick=`changeStatus(${order.id},'pending')`)
            | ⏳ انتظار

          button(onclick=`changeStatus(${order.id},'processing')`)
            | 📦 تجهيز

          button(onclick=`changeStatus(${order.id},'delivered')`)
            | ✅ تم التوصيل

          br
          br

          h3 المنتجات:

          ul
            each item in order.items
              li
                | #{item.name} - الكمية: #{item.qty} - السعر: #{item.price}$

    script.
      function changeStatus(id, status){

        fetch('/change-status-ajax/' + id, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded'
          },
          body: 'status=' + status
        })
        .then(res => res.json())
        .then(data => {

          if(data.success){

            let statusSpan =
              document.getElementById('status-' + id);

            statusSpan.innerHTML = data.status;

          }

        })
        .catch(err => {
          console.log(err);
          alert('حدث خطأ');
        });

      }

    include includes/footer