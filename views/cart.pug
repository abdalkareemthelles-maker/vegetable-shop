doctype html
html
  head
    meta(charset="UTF-8")
    title سلة المشتريات
    link(rel="stylesheet", href="/css/style.css")

  body

    include includes/header

    h1 🛒 سلة المشتريات

    a(href="/")
      button متابعة التسوق

    br
    br

    if cart.length === 0

      h2 السلة فارغة

    else

      table(border="1" width="100%")

        tr
          th الصورة
          th المنتج
          th السعر
          th الكمية
          th المجموع
          th التحكم

        each item in cart

          tr

            td
              img(src=item.image width="80")

            td= item.name

            td #{item.price} $

            // 🔥 الكمية (نضيف class للتحديث)
            td.qty= item.qty

            // 🔥 المجموع لكل منتج
            td.total= item.price * item.qty + " $"

            td

              button.plus(data-id=item.id) +
              button.minus(data-id=item.id) -
              button.delete(data-id=item.id) حذف

      br
      br

      h2 المجموع الكلي:
        span#total= total
        |  $

      br

      a(href="/checkout")
        button 💳 إتمام الطلب

    include includes/footer

    // ================= JS =================
    script(src="/js/cart.js")