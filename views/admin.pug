doctype html
html
  head
    meta(charset="UTF-8")
    title لوحة التحكم
    link(rel="stylesheet", href="/css/style.css")

  body

    include includes/header

    h1 لوحة التحكم 🧑‍💼

    // ================= NAV ACTIONS =================
    .admin-actions
      a(href="/add-product")
        button ➕ إضافة منتج

      a(href="/orders")
        button 🧾 الطلبات

      a(href="/dashboard")
        button 📊 الإحصائيات

      a(href="/")
        button 🛒 المتجر

      a(href="/logout")
        button 🚪 خروج

    // ================= PRODUCTS GRID =================
    .products

      each product in products

        .product

          img(src=product.image)

          h3= product.name

          p.price #{product.price} $

          .actions
            a(href=`/edit-product/${product.id}`)
              button.edit ✏️ تعديل

            button.delete(onclick=`deleteProduct(${product.id}, this)`)
              | ❌ حذف

    include includes/footer

    // ================= JS AJAX =================
    script.
      function deleteProduct(id, btn){
        fetch('/delete-product/' + id, {
          method: 'DELETE'
        })
        .then(res => res.json())
        .then(data => {
          if(data.success){
            btn.closest('.product').remove();
          }
        });
      }