doctype html
html
  head
    meta(charset="UTF-8")
    title دخول الأدمن
    link(rel="stylesheet" href="/css/style.css")

  body

    .form-container

      h1 🔐 دخول الأدمن

      form(action="/admin-login" method="POST")

        input(
          type="text"
          name="username"
          placeholder="اسم الأدمن"
          required
